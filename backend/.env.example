# =====================================================================
#  متغيّرات البيئة — انسخ هذا الملف إلى .env وعدّل القيم
#  لا تُودِع .env في git — أضفه إلى .gitignore
# =====================================================================

# رابط اتصال قاعدة البيانات
DATABASE_URL=postgresql://app_role:change_me_in_production@localhost:5432/hospital_db

# مفتاح توقيع JWT — يجب أن يكون طويلاً وعشوائياً في الإنتاج
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# مدة صلاحية Access Token (صيغة ms: 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# مدة صلاحية Refresh Token
JWT_REFRESH_EXPIRES_IN=7d

# منفذ الخادم
PORT=3000

# جولات التشفير لـ bcrypt (10-12 توازن بين الأمان والأداء)
BCRYPT_ROUNDS=12

# بيئة التشغيل: development | production | test
NODE_ENV=development
